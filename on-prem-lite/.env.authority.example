# Copy to .env for docker-compose.authority.yml (on-prem-lite)

# Admin token: gates admin endpoints + enables per-tenant API key isolation.
# REQUIRED in production — leave empty only for a single-tenant localhost dev run.
AUTHORITY_ADMIN_TOKEN=

# Shared HMAC secret for stateless challenge nonces (REQUIRED if running >1
# authority worker/replica so tokens verify across them).
AUTHORITY_NONCE_SECRET=

# Require a verified TDX+vTPM attestation on /license. MUST be true in production.
# false (default) allows a license request with no quote (dev / non-TDX VMs);
# a PRESENT quote is always verified.
REQUIRE_ATTESTATION=false

# Acceptable TCB statuses from dstack-verifier (empty ⇒ deny everything).
ALLOWED_TCB_STATUSES=UpToDate,SWHardeningNeeded

# License expiry. TTL default 30d; set very large (e.g. 315360000 = 10y) for a
# trial that never needs renewal. Per-tenant override lives in the store.
LICENSE_TTL_SECS=2592000
LICENSE_GRACE_SECS=300

# Policy seed (applied only on first boot when the store file is absent;
# thereafter manage live via the admin API).
#   launcher compose hashes (G6) — comma-separated; fail-closed (empty ⇒ deny).
ALLOWED_LAUNCHER_COMPOSE_HASHES=
#   os-image hash (G4) — OPTIONAL; enforced only when set.
EXPECTED_OS_IMAGE_HASH=

# PCCS endpoint dstack-verifier uses for TDX quote collateral.
PCCS_URL=https://pccs.phala.network
