# SPDX-License-Identifier: Apache-2.0
# Copy to config.env and fill in. Sourced by the on-prem-lite deploy/license
# scripts (lib.sh). The lite profile is a SINGLE workload CVM, no KMS.

# ════════════════════════════════════════════════════════════════════════════
# VENDOR fields (deploy-authority.sh, vendor-release.sh)
# ════════════════════════════════════════════════════════════════════════════

# Where the vendor authority listens (lite uses :8084). vendor-release.sh and the
# operator courier hit this. A REMOTE operator must reach it over TLS — front it
# with a reverse proxy and set https://<host>; plaintext http:// is only safe
# same-host / on a trusted private network (the api key is a bearer token).
AUTHORITY_URL=http://localhost:8084

# Admin bearer token gating the admin API + per-tenant api-key isolation. Also
# read by docker-compose.authority.yml (deploy-authority.sh passes this env-file).
# REQUIRED in production; leave empty only for a single-tenant localhost dev run.
AUTHORITY_ADMIN_TOKEN=

# Vendor public registry: build/encrypt/push target for the lite-launcher + the
# JWE-encrypted workload image.
PUBREG=cr.kvin.wang

# Global image-encryption key id (mint once on the authority, reuse per release).
IMAGE_KID=vendor-2026h1

# Source image to JWE-encrypt into the workload the launcher will run.
WORKLOAD_SRC=traefik/whoami:latest

# Encrypted image name (in PUBREG and, once synced, the operator AR).
WORKLOAD_NAME=whoami-enc

# Prebuilt lite-launcher source: pulled + retagged into $PUBREG/lite-launcher:latest.
# Blank ⇒ build from on-prem-lite/launcher/Dockerfile (the gate-enforcing code — a
# real release should build its own and pin its own digest).
LITE_LAUNCHER_SRC=cr.kvin.wang/lite-launcher:latest

# Tenant id the workload belongs to (created on the authority if absent).
USER_ID=acme

# Workload app id (40 hex). Blank ⇒ the authority assigns one; vendor-release.sh
# captures it into the release manifest and pins it into the measured compose.
APP_ID=

# ════════════════════════════════════════════════════════════════════════════
# OPERATOR fields (operator-deploy.sh, sync-image.sh)
# ════════════════════════════════════════════════════════════════════════════

# GCP project + zone the single workload CVM is deployed into.
GCP_PROJECT=
GCP_ZONE=

# Operator Artifact Registry the no-internet CVM pulls from (Private Google
# Access). The encrypted workload + lite-launcher are synced here from $PUBREG.
AR_LOCATION=us-central1
AR_PROJECT=
AR_REPO=dstack-private

# Published dstack OS version (DOTTED — used by `dstack-cloud pull`); the scripts
# derive the dashed app.json os_image name automatically.
OS_VERSION=dstack-cloud-nvidia-0.6.1

# Static internal IP for the workload CVM (reserved by operator-deploy.sh).
WORKLOAD_IP=10.128.15.240

# Per-tenant api key (multi-user mode). Used by the operator courier run to
# authenticate to the authority. vendor-release.sh prints it when it creates the
# tenant; hand it to the operator.
AUTHORITY_API_KEY=

# DSTACK_CLOUD=dstack-cloud             # override if dstack-cloud isn't on PATH
