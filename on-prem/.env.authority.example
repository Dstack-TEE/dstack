# Copy to .env for docker-compose.authority.yml

# Multi-user mode: set a strong admin token (enables admin endpoints + per-user
# API keys). Leave empty for legacy open/dev mode.
AUTHORITY_ADMIN_TOKEN=

# Shared HMAC secret for stateless challenge nonces (REQUIRED if running >1
# authority worker/replica so tokens verify across them).
AUTHORITY_NONCE_SECRET=

# Require a verified TDX attestation on provision. MUST be true in production.
# false (default) allows provisioning without a quote (dev / non-TDX VMs).
REQUIRE_ATTESTATION=false

# Acceptable TCB statuses from dstack-verifier.
ALLOWED_TCB_STATUSES=UpToDate,SWHardeningNeeded

# PCCS endpoint dstack-verifier uses for TDX quote collateral.
PCCS_URL=https://pccs.phala.network
