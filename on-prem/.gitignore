# secrets / environment-specific — commit the .example templates instead.
# (gitignore has no inline comments; keep patterns on their own lines.)

# core: vendor-host authority secrets
.env.authority
intake.env

# GCP KMS-CVM env + script secrets
gcp/.env
gcp/scripts/config.env
gcp/scripts/authority.env

# generated Secure Web Proxy artifacts (includes the private key) — regenerated by setup-swp.sh
gcp/scripts/.swp/

# environment-specific working deployments (not reusable code)
gcp/deploy/

# python bytecode
__pycache__/
*.pyc
