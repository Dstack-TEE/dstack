# Copy to .env and fill in values

# Pre-built dstack-kms image (from dstacktee/dstack-kms on Docker Hub)
KMS_IMAGE=cr.kvin.wang/dstack-kms:latest

# key-broker image (build locally or push to GCP Artifact Registry)
KEY_BROKER_IMAGE=cr.kvin.wang/key-broker:latest

# Ed25519 public key from vendor authority (base64, 32 bytes)
# Fetch with: python3 authority/kms_ctl.py ... or curl http://<authority>/api/v1/authority-pubkey
# Leave empty to skip signature verification (dev only)
AUTHORITY_PUBKEY=

# Lease TTL in seconds (default 1 hour)
LEASE_TTL_SECS=3600
