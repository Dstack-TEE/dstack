# SPDX-License-Identifier: Apache-2.0
# Copy to config.env and fill in. Sourced by the deploy/provision scripts.

# ─── GCP / customer KMS CVM ───────────────────────────────────────────────────
GCP_PROJECT=wuhan-workshop
GCP_ZONE=us-central1-a
KMS_VM=dstack-kms                      # the TDX Confidential VM running KMS+key-broker (== app.json instance_name)
SSH_KEY="$HOME/.ssh/id_ed25519"        # key registered on the dstack OS (GitHub key)

# ─── GCP internal registry (Artifact Registry) — no-internet CVMs pull here ───
AR_LOCATION=us-central1
AR_PROJECT=wuhan-workshop
AR_REPO=dstack-private
SRC_AUTHFILE=/home/kvin/.docker/config.json   # creds for the EXTERNAL source registry
# images the CVM pulls (point at AR once synced with sync-image.sh):
KMS_IMAGE=us-central1-docker.pkg.dev/wuhan-workshop/dstack-private/dstack-kms:latest
KEY_BROKER_IMAGE=us-central1-docker.pkg.dev/wuhan-workshop/dstack-private/key-broker:latest

# ─── vendor authority stack (authority + dstack-verifier) ───────────────────────
AUTHORITY_URL=http://localhost:8083     # where the vendor authority listens (this host)
VERIFIER_IMAGE=cr.kvin.wang/dstack-verifier:latest

# Multi-user mode: set a strong admin token to enable admin endpoints + per-user
# API keys. Leave empty for open/dev mode.
AUTHORITY_ADMIN_TOKEN=
# Shared HMAC secret for stateless challenge nonces (REQUIRED for >1 worker).
AUTHORITY_NONCE_SECRET=change-me-nonce-secret
# Persistent Ed25519 AuthBundle signing key seed (32 bytes hex/base64). If empty
# the authority persists a generated key to /data/signing.key in its volume.
AUTHORITY_SIGNING_KEY=

# Require a verified TDX attestation on provision (MUST be true in production).
REQUIRE_ATTESTATION=true
# Vendor-approved KMS OS image UKI hash (hex). On GCP the verifier reads the
# actual UKI hash from the vTPM event log (PCR2 Event 28) and compares to this.
# Get it once from a first attest (see DEPLOYMENT.md §Verify).
EXPECTED_OS_IMAGE_HASH=fd5fbaf59b09a5a55e25401f3f92d055ad3fa702b131cddef0195dfec3041f47
# PCCS for TDX quote collateral.
PCCS_URL=https://api.trustedservices.intel.com

# ─── provisioning (courier attest) ────────────────────────────────────────────
USER_ID=acme-prod                      # tenant id (multi-user: must exist + use its api key)
AUTHORITY_API_KEY=                      # per-user api key (multi-user mode only)
KMS_LOCAL_PORT=8001                    # local port the IAP tunnel forwards to key-broker:8001

# ─── vendor release (vendor-release.sh / vendor-add-tenant.sh) ─────────────────
PUBREG=cr.kvin.wang                    # vendor public registry (build/encrypt/push target)
IMAGE_KID=vendor-2026h1                 # global image-encryption key id (mint once, reuse)
APP_ID=078a2ffea340832bb5d3e9eb317aad6aed067d49   # workload app id (40 hex)
WORKLOAD_SRC=traefik/whoami:latest      # source image to JWE-encrypt
WORKLOAD_NAME=whoami-enc                # encrypted image name (in PUBREG and AR)

# ─── operator one-command deploy (operator-deploy.sh) ─────────────────────────
OS_IMAGE=dstack-cloud-nvidia-0-6-1      # the published dstack OS version to pull + deploy
KMS_IP=10.128.15.220                    # KMS static internal IP (== cert SAN == kms_urls host)
LAUNCHER_IP=10.128.15.230               # workload CVM static internal IP
SWP_PROXY=10.128.0.53:80                # egress proxy IP:port for the KMS (leave empty to skip)
# DSTACK_CLOUD=dstack-cloud             # override if dstack-cloud isn't on PATH
